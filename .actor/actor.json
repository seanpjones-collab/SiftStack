{
    "actorSpecification": 1,
    "name": "siftstack-oh-scraper",
    "title": "SiftStack — Ohio Civil-Authority Scraper",
    "description": "Day-0 first-to-market foreclosure + probate data from Cuyahoga, Summit, and Stark counties in Ohio. Every HTTP call routes through Apify's residential proxy to protect against IP fingerprinting. Enriches via Smarty, Zillow, obituary search, and Tracerfy; exports to DataSift.ai and Slack.",
    "version": "1.1",
    "buildTag": "latest",
    "input": "./input_schema.json",
    "dockerfile": "../Dockerfile",
    "storages": {
        "dataset": {
            "actorSpecification": 1,
            "title": "SiftStack OH Records",
            "views": {
                "overview": {
                    "title": "Overview",
                    "transformation": {
                        "fields": [
                            "date_added",
                            "address",
                            "city",
                            "state",
                            "zip",
                            "owner_name",
                            "notice_type",
                            "county",
                            "decedent_name",
                            "parcel_id",
                            "source_url"
                        ]
                    },
                    "display": {
                        "component": "table",
                        "properties": {
                            "date_added": { "label": "Date", "format": "text" },
                            "address": { "label": "Address", "format": "text" },
                            "city": { "label": "City", "format": "text" },
                            "owner_name": { "label": "Owner / PR", "format": "text" },
                            "notice_type": { "label": "Type", "format": "text" },
                            "county": { "label": "County", "format": "text" },
                            "decedent_name": { "label": "Decedent", "format": "text" },
                            "parcel_id": { "label": "Parcel", "format": "text" }
                        }
                    }
                }
            }
        }
    }
}
