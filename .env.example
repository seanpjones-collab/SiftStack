# ── Data Source Credentials ─────────────────────────────────────────
# Required for web scraping (tnpublicnotice.com or your state's notice site)
TNPN_EMAIL=your_email@example.com
TNPN_PASSWORD=your_password_here

# Akron Legal News (akronlegalnews.com) — primary source for Summit County, OH
# Paid subscription (~$75/yr) unlocks full notice details including fiduciaries,
# addresses, and Sheriff Sale Results.
ALN_EMAIL=your_email@example.com
ALN_PASSWORD=your_password_here

# 2Captcha API key for reCAPTCHA v2 solving (~$2.99/1000 solves)
# Sign up at https://2captcha.com
CAPTCHA_API_KEY=your_2captcha_api_key_here

# ── CRM Integration ────────────────────────────────────────────────
# DataSift.ai (formerly REISift) — automated upload + enrich + skip trace
DATASIFT_EMAIL=your_datasift_email@example.com
DATASIFT_PASSWORD=your_datasift_password_here

# ── Enrichment API Keys ────────────────────────────────────────────
# Smarty (address standardization, USPS validation, geocoding)
# Sign up at https://smarty.com — free tier: 250 lookups/month
SMARTY_AUTH_ID=your_smarty_auth_id
SMARTY_AUTH_TOKEN=your_smarty_auth_token

# OpenWeb Ninja (Zillow property data — Zestimate, MLS, equity)
# Sign up at https://openwebninja.com — free tier: 100 requests/month
OPENWEBNINJA_API_KEY=your_openwebninja_api_key

# Anthropic (Claude Haiku — LLM parsing, obituary search, entity research)
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Serper.dev (Google Search — DM address lookup)
# Sign up at https://serper.dev — free tier: 2,500 queries
SERPER_API_KEY=your_serper_api_key

# Firecrawl (JS-rendered page scraping — DM address extraction)
# Sign up at https://firecrawl.dev — free tier: 500 pages
FIRECRAWL_API_KEY=fc-your-key-here

# ── Skip Trace & Phone Validation ──────────────────────────────────
# Tracerfy (batch skip trace — phones, emails, mailing addresses)
# $0.02/record — sign up at https://tracerfy.com
TRACERFY_API_KEY=your_tracerfy_api_key

# Trestle (phone scoring — 5-tier dial priority)
# $0.015/phone — sign up at https://trestleiq.com
TRESTLE_API_KEY=your_trestle_api_key

# ── Notifications ──────────────────────────────────────────────────
# Slack or Discord webhook for daily run summaries + error alerts
# Discord: use /slack suffix: https://discord.com/api/webhooks/{id}/{token}/slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Dropbox Auto-Polling (courthouse photo import) ─────────────────
# Create a Dropbox app at https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=your_app_key
DROPBOX_APP_SECRET=your_app_secret
DROPBOX_REFRESH_TOKEN=your_refresh_token
DROPBOX_POLL_INTERVAL=900
DROPBOX_ROOT_FOLDER=TN Public Notice

# ── LLM Backend (optional — defaults to Anthropic) ─────────────────
# Switch to local Ollama or OpenRouter for cheaper/free LLM calls
LLM_BACKEND=anthropic
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434/v1/
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# ── Google Drive (optional — CSV backup) ────────────────────────────
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# GOOGLE_SERVICE_ACCOUNT_KEY=base64_encoded_json_key

# ── Ancestry.com (optional — SSDI + obituary collection) ───────────
# Requires World Explorer subscription ($29/month)
# ANCESTRY_EMAIL=your_email@example.com
# ANCESTRY_PASSWORD=your_password
